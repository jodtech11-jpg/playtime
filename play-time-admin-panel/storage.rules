rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ---------- Helpers ----------
    function isAuthenticated() {
      return request.auth != null;
    }

    function userExists() {
      return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return userExists() ?
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role :
             null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && userExists() && getUserRole() == 'super_admin';
    }

    function isVenueManager() {
      return isAuthenticated() && userExists() && getUserRole() == 'venue_manager';
    }

    function getManagedVenues() {
      return userExists() ?
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.managedVenues :
             [];
    }

    function ownsVenue(venueId) {
      return isSuperAdmin() ||
             (isVenueManager() && venueId in getManagedVenues());
    }

    function isAllowedImageType() {
      return request.resource.contentType == 'image/jpeg' ||
             request.resource.contentType == 'image/jpg' ||
             request.resource.contentType == 'image/png' ||
             request.resource.contentType == 'image/webp';
    }

    function underMaxSize() {
      // Max 5 MB per image upload.
      return request.resource.size < 5 * 1024 * 1024;
    }

    // ---------- Venue images ----------
    // Only super admins or the venue's manager may upload/replace venue images.
    match /venues/{venueId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if (isSuperAdmin() || ownsVenue(venueId)) &&
                   isAllowedImageType() &&
                   underMaxSize();
    }

    // Temporary venue images (before a venueId is assigned).
    match /venues/temp/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if (isSuperAdmin() || isVenueManager()) &&
                   isAllowedImageType() &&
                   underMaxSize();
    }

    // ---------- User avatars ----------
    match /users/{userId}/avatar/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                   (userId == request.auth.uid || isSuperAdmin()) &&
                   isAllowedImageType() &&
                   underMaxSize();
    }

    // ---------- Post images (Social Feed) ----------
    // Path convention: posts/{userId}_{postId}/... OR posts/{postId}/...
    // We allow any authenticated user to upload their own post images but require
    // image content-type + size limit.
    match /posts/{postId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                   isAllowedImageType() &&
                   underMaxSize();
    }

    // ---------- Team images (TeamUp) ----------
    match /teams/{teamId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                   isAllowedImageType() &&
                   underMaxSize();
    }

    // ---------- Marketing campaigns (Super Admin only) ----------
    match /marketing/{campaignId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() && isAllowedImageType() && underMaxSize();
    }

    // ---------- Tournaments (Super Admin only) ----------
    match /tournaments/{tournamentId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() && isAllowedImageType() && underMaxSize();
    }

    // ---------- Products (Super Admin only) ----------
    match /products/{productId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() && isAllowedImageType() && underMaxSize();
    }

    // Temporary product images (before product ID is assigned).
    match /products/temp/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() && isAllowedImageType() && underMaxSize();
    }

    // ---------- Expense receipts ----------
    match /expenses/{expenseId}/{allPaths=**} {
      allow read: if isSuperAdmin() || isVenueManager();
      allow write: if (isSuperAdmin() || isVenueManager()) && underMaxSize();
    }

    // ---------- Staff avatars ----------
    match /staff/{staffId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if (isSuperAdmin() || isVenueManager()) &&
                   isAllowedImageType() &&
                   underMaxSize();
    }

    // ---------- App Settings (Logo, etc. — Super Admin only) ----------
    match /app-settings/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() && underMaxSize();
    }

    // ---------- Default deny ----------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
