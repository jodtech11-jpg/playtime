rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ?
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data :
             null;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData() != null &&
             getUserData().role == 'super_admin';
    }

    function isVenueManager() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData() != null &&
             getUserData().role == 'venue_manager';
    }

    function ownsVenue(venueId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (isVenueManager() &&
         getUserData() != null &&
         'managedVenues' in getUserData() &&
         venueId in getUserData().managedVenues)
      );
    }

    // Create-time binding: the new document's userId must equal the caller's uid.
    function createdByCaller() {
      return request.resource.data.userId == request.auth.uid;
    }

    // Pending/Confirmed bookings expose time window only (for slot availability queries).
    function isActiveBooking() {
      return resource.data.status == 'Pending' || resource.data.status == 'Confirmed';
    }

    // ---------- Users ----------
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        userId == request.auth.uid ||
        (request.auth.token.phone_number != null &&
         resource.data.phone == request.auth.token.phone_number) ||
        (request.auth.token.email != null &&
         resource.data.email == request.auth.token.email) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (isSuperAdmin() || isVenueManager()))
      );
      // - Unauthenticated vendor signup: status=Pending, role=venue_manager, self-id.
      // - Authenticated self-signup: role=player or null.
      // - Admins/venue_managers can create any user.
      allow create: if (
        (request.auth == null &&
         request.resource.data.status == 'Pending' &&
         request.resource.data.role == 'venue_manager' &&
         userId == request.resource.data.id) ||
        (isAuthenticated() && userId == request.auth.uid &&
         (request.resource.data.role == 'player' || request.resource.data.role == null)) ||
        (isAuthenticated() &&
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (isSuperAdmin() || isVenueManager()))
      );
      allow update: if isAuthenticated() && (
        userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (isSuperAdmin() || isVenueManager()))
      );
      allow delete: if isAuthenticated() &&
                     exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                     isSuperAdmin();

      match /favorites/{favoriteId} {
        allow read: if isAuthenticated() && userId == request.auth.uid;
        allow create: if isAuthenticated() &&
                       userId == request.auth.uid &&
                       request.resource.data.venueId is string;
        allow delete: if isAuthenticated() && userId == request.auth.uid;
      }
    }

    // ---------- Roles (Super Admin only) ----------
    match /roles/{roleId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Permissions (Super Admin only) ----------
    match /permissions/{permissionId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Venues ----------
    match /venues/{venueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if ownsVenue(venueId);
      allow delete: if isSuperAdmin();
    }

    // ---------- Courts ----------
    match /courts/{courtId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow delete: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
    }

    // ---------- Bookings ----------
    // Read: owner, venue manager, super admin, OR active bookings for any signed-in
    // user (mobile slot/availability queries on venueId + courtId + status).
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.userId == request.auth.uid ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        isActiveBooking()
      );
      allow create: if isAuthenticated() && (
        createdByCaller() ||
        isSuperAdmin() ||
        (isVenueManager() &&
         request.resource.data.venueId != null &&
         ownsVenue(request.resource.data.venueId))
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // ---------- Serialized slot locks ----------
    // Used with transactional booking creation (same start/end per court).
    // The lock must be owned by the caller; only the owner (or admin) may delete.
    match /booking_slot_locks/{lockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && createdByCaller();
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // ---------- Memberships ----------
    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        resource.data.userId == request.auth.uid
      );
      // Users create memberships for themselves; admins can create for anyone.
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        isVenueManager() ||
        createdByCaller()
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow delete: if isSuperAdmin();
    }

    // ---------- Membership Plans ----------
    match /membershipPlans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow delete: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
    }

    // ---------- Staff ----------
    match /staff/{staffId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow delete: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
    }

    // ---------- Expenses ----------
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow delete: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
    }

    // ---------- Salary Records ----------
    match /salaryRecords/{recordId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow delete: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
    }

    // ---------- Posts (Social Feed) ----------
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                     createdByCaller() &&
                     (request.resource.data.status == 'Pending' || request.resource.data.status == 'Approved');
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.userId == request.auth.uid ||
        // Social interaction counter updates (counters only; content unchanged)
        (
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['likes', 'comments', 'updatedAt']) &&
          request.resource.data.content == resource.data.content
        )
      );
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        resource.data.userId == request.auth.uid
      );

      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && createdByCaller();
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          isSuperAdmin()
        );
      }

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && createdByCaller();
        allow update: if isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          isSuperAdmin()
        );
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          isSuperAdmin()
        );
      }
    }

    // ---------- Categories (Super Admin only) ----------
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Sports (Super Admin only) ----------
    match /sports/{sportId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
    }

    // ---------- Products (Super Admin only) ----------
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Quick Matches ----------
    match /quickMatches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
    }

    // ---------- Leaderboards / Polls / Flash Deals ----------
    match /leaderboards/{leaderboardId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }
    match /polls/{pollId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }
    match /flashDeals/{dealId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
    }

    // ---------- Orders ----------
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && createdByCaller();
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow delete: if isSuperAdmin();
    }

    // ---------- Tournaments ----------
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Reports (moderation) ----------
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      // Any authenticated user can create a report about themselves/other content,
      // but the report must carry their uid as reporterId/userId to prevent impersonation.
      allow create: if isAuthenticated() &&
                     (request.resource.data.userId == request.auth.uid ||
                      request.resource.data.reporterId == request.auth.uid);
      allow update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Marketing Campaigns ----------
    match /marketingCampaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Support Tickets ----------
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.assignedTo != null && resource.data.assignedTo == request.auth.uid)
      );
      allow create: if isAuthenticated() && createdByCaller();
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.assignedTo != null && resource.data.assignedTo == request.auth.uid)
      );
      allow delete: if isSuperAdmin();
    }

    // ---------- App Settings ----------
    match /appSettings/{settingsId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Landing Page / CMS Pages (public read) ----------
    match /landingPage/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }
    match /cmsPages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Notifications ----------
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        isVenueManager()
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        isVenueManager()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        userId == request.auth.uid ||
        isSuperAdmin() ||
        isVenueManager()
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && (
        userId == request.auth.uid ||
        isSuperAdmin() ||
        isVenueManager()
      );
      allow delete: if isAuthenticated() && (
        userId == request.auth.uid ||
        isSuperAdmin()
      );
    }

    // ---------- Teams (TeamUp) ----------
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                     request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.createdBy == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.createdBy == request.auth.uid)
      );
    }

    // ---------- FCM Tokens ----------
    match /fcmTokens/{tokenId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin() || isVenueManager());
      allow create: if isAuthenticated() && createdByCaller();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin() || isVenueManager());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin() || isVenueManager());
    }

    // ---------- Invoices ----------
    // Only admins / venue managers can create invoices. Only super admins can update/delete.
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Payments ----------
    // Clients record payments for themselves (userId must match the caller).
    // The Razorpay webhook (Cloud Function) writes server-verified records via Admin SDK,
    // which bypasses these rules.
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId)) ||
        (resource != null && resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        isVenueManager() ||
        createdByCaller()
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Settlements ----------
    match /settlements/{settlementId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (resource != null && resource.data.venueId != null && ownsVenue(resource.data.venueId))
      );
      allow create: if isAuthenticated() && (isSuperAdmin() || isVenueManager());
      allow update: if isAuthenticated() && isSuperAdmin();
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Wallet Transactions ----------
    match /walletTransactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        isVenueManager()
      );
      allow create: if isAuthenticated() && createdByCaller();
      allow update: if isAuthenticated() && isSuperAdmin();
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // ---------- Activity / Audit Log ----------
    // Authenticated callers may append entries, but the entry's userId must match
    // the caller's uid to prevent audit-log forgery. Never updatable or deletable.
    match /activityLog/{logId} {
      allow read: if isAuthenticated() && isSuperAdmin();
      allow create: if isAuthenticated() && createdByCaller();
      allow update, delete: if false;
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
