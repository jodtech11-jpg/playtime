# Play Time Admin Panel – environment variables
# Copy this file to .env and fill in your values. Do not commit .env.

# ============== Firebase (required) ==============
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# ============== FCM / Push (optional) ==============
# Cloud Function URL (recommended) or Server Key (not for production)
VITE_FCM_CLOUD_FUNCTION_URL=
VITE_FCM_SERVER_KEY=

# ============== Google Maps (optional) ==============
VITE_GOOGLE_MAPS_API_KEY=

# ============== Other (optional) ==============
# Used by scripts/tooling that read process.env (e.g. vite.config)
GEMINI_API_KEY=
